{
	"$schema": "https://playground.wordpress.net/blueprint-schema.json",
	"login": true,
	"landingPage": "/wp-admin/post.php?post=2&action=edit",
	"preferredVersions": {
	  "php": "8.3",
	  "wp": "latest"
	},
	"features": {
	  "networking": true
	},
	"steps": [
	  {
		"step": "installTheme",
		"themeZipFile": {
		  "resource": "url",
		  "url": "https://your-site.com/your-theme.zip"
		}
	  },
	  {
		"step": "activateTheme",
		"themeFolderName": "your-theme-folder-name"
	  },
	  {
		"step": "runPHP",
		"code": "<?php require '/wordpress/wp-load.php'; update_user_meta( 1, 'gutenbergWelcomeGuide', false ); update_user_meta( 1, 'core_block_editor_is_new_user', false ); ?>"
	  }
	]
  }